# DO NOT REMOVE. CLOUDLINUX PASSENGER CONFIGURATION BEGIN
PassengerAppRoot "/home/maddasys/public_html/api/milk-collection-api"
PassengerBaseURI "/"
PassengerNodejs "/home/maddasys/nodevenv/public_html/api/milk-collection-api/19/bin/node"
PassengerAppType node
PassengerStartupFile server.js
# DO NOT REMOVE. CLOUDLINUX PASSENGER CONFIGURATION END

# ============================================================================
# Milk Collection API - cPanel Configuration
# Domain: backend.maddasystems.co.ke
# Directory: /public_html/api/milk-collection-api/
#
# IMPORTANT (v2.10.110): ONLY the cPanel-managed Passenger header block above
# is allowed. Do NOT add a second PassengerNodejs/PassengerAppRoot/
# PassengerStartupFile block below — Apache uses the LAST directive, and a
# Node version mismatch with the cPanel Node Selector registration causes
# "Can't acquire lock for app" failures on restart.
# ============================================================================

SetEnv NODE_ENV production
SetEnv MYSQL_HOST localhost
SetEnv MYSQL_DATABASE maddasys_milk_collection_pwa
SetEnv MYSQL_USER maddasys_wycliff
SetEnv MYSQL_PASSWORD 0741899183Mutee
SetEnv MYSQL_PORT 3306
SetEnv PORT 3000

# v2.10.108 — pool tunables (stay within cPanel max_user_connections=40)
SetEnv MYSQL_POOL_LIMIT 8
SetEnv MYSQL_QUEUE_LIMIT 50
SetEnv REQUEST_TIMEOUT_MS 30000

# CORS headers for all origins (including Capacitor app and Netlify)
<IfModule mod_headers.c>
  Header always set Access-Control-Allow-Origin "*"
  Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS, PATCH"
  Header always set Access-Control-Allow-Headers "Content-Type, Accept, Authorization, X-Requested-With, Origin, X-Device-Fingerprint, X-App-Origin"
  Header always set Access-Control-Max-Age "86400"
</IfModule>

# Handle OPTIONS preflight requests at Apache level
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{REQUEST_METHOD} OPTIONS
  RewriteRule ^(.*)$ - [L]
</IfModule>

# Block direct access to sensitive files
<FilesMatch "^(server\.js|package\.json|package-lock\.json|\.env|node_modules)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Prevent directory listing
Options -Indexes

# Disable server signature
ServerSignature Off

# DO NOT REMOVE OR MODIFY. CLOUDLINUX ENV VARS CONFIGURATION BEGIN
<IfModule Litespeed>
SetEnv MYSQL_DATABASE maddasys_milk_collection_pwa
SetEnv MYSQL_HOST localhost
SetEnv MYSQL_PASSWORD 0741899183Mutee
SetEnv MYSQL_PORT 3306
SetEnv NODE_ENV production
SetEnv PORT 3000
SetEnv MYSQL_USER maddasys_wycliff
</IfModule>
# DO NOT REMOVE OR MODIFY. CLOUDLINUX ENV VARS CONFIGURATION END
